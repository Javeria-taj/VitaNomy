generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NEXTAUTH MODELS ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // nullable — populated only for credential logins
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── VITANOMY DOMAIN MODELS ──────────────────────────────────────────────────

model HealthSession {
  id          String   @id @default(cuid())
  patientId   String   @unique
  mode        String
  createdAt   DateTime @default(now())
  record      PatientRecord?
  analyses    Analysis[]
}

model PatientRecord {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  session     HealthSession  @relation(fields: [sessionId], references: [id])
  mode        String
  inputData   Json
  createdAt   DateTime @default(now())
}

model Analysis {
  id          String   @id @default(cuid())
  sessionId   String
  session     HealthSession  @relation(fields: [sessionId], references: [id])
  riskScores  Json
  insights    Json
  createdAt   DateTime @default(now())
}
